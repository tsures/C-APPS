<Window x:Class="AudioAmplifierMockup.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AudioAmplifierMockup"
        mc:Ignorable="d"
          Title="Windows Audio Amplifier"
        Width="760"
        Height="480"
        MinWidth="720"
        MinHeight="440"
        WindowStartupLocation="CenterScreen"
        Background="#161616">

    <Window.Resources>
        <DropShadowEffect x:Key="SoftShadow"
                          BlurRadius="24"
                          ShadowDepth="0"
                          Opacity="0.45"/>

        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="Background" Value="#242424"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Effect" Value="{StaticResource SoftShadow}"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#F5F5F5"/>
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,0"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="8"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Border Style="{StaticResource PanelBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <DockPanel Grid.Row="0" LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="AUDIO MASTER"
                                   Foreground="#F2F2F2"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   />

                        <TextBlock Text="Windows Default Output Controller"
                                   Foreground="#A0A0A0"
                                   FontSize="14"
                                   Margin="2,4,0,0"/>
                    </StackPanel>

                    <Ellipse DockPanel.Dock="Right"
                             Width="18"
                             Height="18"
                             Fill="#25D366"
                             Margin="0,8,4,0"/>
                </DockPanel>

                <!-- Amplifier Body -->
                <Grid Grid.Row="1" Margin="0,26,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LCD Display -->
                    <Border Grid.Column="0"
                            CornerRadius="18"
                            Background="#06140D"
                            BorderBrush="#2EFF8A"
                            BorderThickness="2"
                            Padding="20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="LCD DISPLAY"
                                       Foreground="#57FF9A"
                                       FontSize="13"
                                       FontWeight="Bold"
                                        />

                            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                                <TextBlock Text="CURRENT DEVICE"
                                           Foreground="#7CFFB2"
                                           FontSize="12"
                                            />

                                <TextBlock Text="{Binding CurrentDeviceName}"
                                           Foreground="#B8FFD2"
                                           FontFamily="Consolas"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           TextWrapping="Wrap"
                                           Margin="0,20,0,18"/>

                                <TextBlock Text="DATE / TIME"
                                           Foreground="#7CFFB2"
                                           FontSize="12"
                                           />

                                <TextBlock Text="{Binding DateTimeText}"
                                           Foreground="#B8FFD2"
                                           FontFamily="Consolas"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Margin="0,6,0,18"/>

                                <TextBlock Text="VOLUME"
                                           Foreground="#7CFFB2"
                                           FontSize="12"
                                           />

                                <TextBlock Text="{Binding VolumeDisplay}"
                                           Foreground="#B8FFD2"
                                           FontFamily="Consolas"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Left"/>
                            </StackPanel>

                            <TextBlock Grid.Row="2"
                                       Text="{Binding StatusText}"
                                       Foreground="#57FF9A"
                                       FontSize="13"
                                       FontFamily="Consolas"/>
                        </Grid>
                    </Border>

                    <!-- Controls -->
                    <Border Grid.Column="2"
                            CornerRadius="18"
                            Background="#1B1B1B"
                            BorderBrush="#333333"
                            BorderThickness="1"
                            Padding="18">
                        <StackPanel>
                            <TextBlock Text="OUTPUT DEVICE"
                                       Foreground="#F2F2F2"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>

                            <ComboBox ItemsSource="{Binding Devices}"
                                      SelectedItem="{Binding SelectedDevice, Mode=TwoWay}"
                                      DisplayMemberPath="Name"/>

                            <Button Content="SET DEFAULT"
                                    Command="{Binding SetDefaultDeviceCommand}"
                                    Margin="0,14,0,20"/>

                            <TextBlock Text="MASTER VOLUME"
                                       Foreground="#F2F2F2"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>

                            <Slider Minimum="1"
                                    Maximum="100"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding Volume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Height="42"/>

                            <DockPanel Margin="0,8,0,12">
                                <TextBlock Text="1"
                                           DockPanel.Dock="Left"
                                           Foreground="#999999"/>

                                <TextBlock Text="100"
                                           DockPanel.Dock="Right"
                                           Foreground="#999999"/>
                            </DockPanel>

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center">
                                <Button Content="-"
                                        Width="56"
                                        Command="{Binding VolumeDownCommand}"/>

                                <Button Content="+"
                                        Width="56"
                                        Command="{Binding VolumeUpCommand}"/>
                            </StackPanel>

                            <Button Content="REFRESH"
                                    Command="{Binding RefreshCommand}"
                                    Margin="0,22,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Footer -->
                <TextBlock Grid.Row="2"
                           Text="Mock amplifier UI for Windows default audio output and master volume"
                           Foreground="#777777"
                           FontSize="12"
                           HorizontalAlignment="Center"/>
            </Grid>
        </Border>
        </Grid>
</Window>
