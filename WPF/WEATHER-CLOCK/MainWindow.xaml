<Window x:Class="WEATHER_CLOCK.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WEATHER_CLOCK"
        mc:Ignorable="d"
        Title="MainWindow"         
        Height="220"
        Width="800"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True"
        ShowInTaskbar="True"
        Topmost="True">
    <Border CornerRadius="10"
            BorderThickness="3"
            BorderBrush="#4728FF"
            Background="#0A0A0F"            
            Padding="6"
            SnapsToDevicePixels="True"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">
    <Border CornerRadius="10"
            BorderThickness="3"
            BorderBrush="#47C8FF"
            Background="#0A0A0F"            
            Padding="18"
            SnapsToDevicePixels="True"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="2.5*" />
                <ColumnDefinition Width="4.5*" />
            </Grid.ColumnDefinitions>


            <!-- Left: Time + Date -->
            <StackPanel Grid.Column="0"
                        VerticalAlignment="Center">
                <TextBlock Text="{Binding TimeText}"
                           Foreground="White"
                           FontSize="32"
                           FontWeight="Bold"
                           FontFamily="Consolas"
                            />

                <TextBlock Text="{Binding DateText}"
                           Margin="0,4,0,0"
                           Foreground="White"
                           FontSize="18"
                           FontFamily="Consolas" />
            </StackPanel>

            <!-- Center: Current weather -->
            <Grid Grid.Column="1"
                  Margin="20,0,20,0"
                  VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">
                    <TextBlock Text="{Binding WeatherIcon}"
                               Foreground="#D9F5FF"
                               FontSize="30"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0" />

                    <TextBlock Text="{Binding CurrentTemperature}"
                               Foreground="White"
                               FontSize="32"
                               FontWeight="Bold"
                               FontFamily="Consolas"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Row="1"
                            Margin="0,8,0,0"
                            HorizontalAlignment="Center">
                    <TextBlock Text="{Binding HighLowText}"
                               Foreground="#D7E7F2"
                               FontSize="28"
                               FontFamily="Consolas"
                               HorizontalAlignment="Center" />

                    <TextBlock Text="{Binding LocationText}"
                               Foreground="#95A8B5"
                               FontSize="12"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>

            <!-- Right: Forecast -->
            <ItemsControl Grid.Column="2"
                          ItemsSource="{Binding Forecast}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="1" Columns="5" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#1E2B34"
                                BorderThickness="1,0,0,0"
                                Padding="10,0,10,0">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{Binding DayName}"
                                           Foreground="#D9E7F1"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center" />

                                <TextBlock Text="{Binding Icon}"
                                           Foreground="#EAF7FF"
                                           FontSize="28"
                                           Margin="0,8,0,8"
                                           HorizontalAlignment="Center" />

                                <TextBlock Text="{Binding TemperatureText}"
                                           Foreground="White"
                                           FontSize="12"
                                           FontFamily="Consolas"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Button Content="✕"
        Command="{Binding CloseCommand}"
        Width="36"
        Height="36"
        HorizontalAlignment="Right"
        VerticalAlignment="Top"
        Margin="0,0,0,0"
        Cursor="Hand"
        Background="Transparent"
        BorderThickness="0"
        Foreground="#BFD9E8"
        FontSize="18" Grid.Column="2"
        FontWeight="Bold">

                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd"
                                Background="Transparent"
                                CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                    </Border>

                                    <ControlTemplate.Triggers>
                                        <!-- Hover -->
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#22FF5C5C"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>

                                        <!-- Pressed -->
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#44FF3B3B"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

    </Border>
    </Border>
</Window>
